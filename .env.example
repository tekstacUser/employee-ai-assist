# Copy to .env before running `docker compose up -d`:
#   cp .env.example .env
#
# Fields marked TODO below are mandatory — the stack will start without
# them, but LangFuse tracing and/or the LiteLLM master key will not work
# correctly, and Step 6 (Chat UI -> LangFuse trace) will fail.
# Fields NOT marked TODO already work out of the box — leave them as-is
# unless you have a specific reason to change them.

# --- Postgres (shared by LangFuse) — already working, no edit needed ---
POSTGRES_USER=llmops
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=langfuse

# --- LangFuse ---------------------------------------------------------
# TODO (mandatory): start the stack first (`docker compose up -d`), open
# http://localhost:3000, sign up, create an organization + project, then
# open Project Settings > API Keys and generate a keypair. Paste the
# values below, then run `docker compose restart litellm` so the new
# keys take effect.
LANGFUSE_SECRET_KEY=                  # TODO: paste your generated LangFuse secret key (starts with sk-lf-)
LANGFUSE_PUBLIC_KEY=                  # TODO: paste your generated LangFuse public key (starts with pk-lf-)
# Already working, no edit needed:
LANGFUSE_NEXTAUTH_SECRET=change-me-too
LANGFUSE_SALT=change-me-salt
LANGFUSE_HOST=http://langfuse:3000

# --- LiteLLM -----------------------------------------------------------
# TODO (mandatory): replace with a real secret string of your choosing.
# This is the key litellm/config.yaml reads via
# `general_settings.master_key: os.environ/LITELLM_MASTER_KEY`, and the
# key the backend uses to authenticate to the LiteLLM proxy.
LITELLM_MASTER_KEY=                   # TODO: set your own value, e.g. sk-litellm-<random string>

# Per-business-unit virtual keys (hr / it / finance) are created AFTER
# the proxy is up, using the master key above and the virtual_keys
# block you configured in litellm/config.yaml (Gap 10):
#   curl -X POST http://localhost:4000/key/generate \
#     -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#     -d '{"models": ["standard-tier"], "metadata": {"bu": "hr"}}'
# This is not a .env edit — it's a one-time setup call you run once the
# stack and your config.yaml Gap 10 values are in place.

# --- Ollama — already working, no edit needed --------------------------
OLLAMA_BASE_URL=http://ollama:11434

# --- Backend — already working, no edit needed --------------------------
BACKEND_PORT=8000
