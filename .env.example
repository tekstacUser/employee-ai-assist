# Copy to .env before running `docker compose up -d`

# --- Postgres (shared by LangFuse) ---
POSTGRES_USER=llmops
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=langfuse

# --- LangFuse ---
LANGFUSE_SECRET_KEY=sk-lf-local-secret-change-me
LANGFUSE_PUBLIC_KEY=pk-lf-local-public-change-me
LANGFUSE_NEXTAUTH_SECRET=change-me-too
LANGFUSE_SALT=change-me-salt
LANGFUSE_HOST=http://langfuse:3000

# --- LiteLLM ---
# Master key used by the backend to call the LiteLLM proxy.
LITELLM_MASTER_KEY=sk-litellm-local-master-change-me
# Per-business-unit virtual keys are created via Gap 5 (Sub-section 1.2)
# and referenced in cost-model.md — generate them after the proxy is up:
#   curl -X POST http://localhost:4000/key/generate \
#     -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#     -d '{"models": ["standard-tier"], "metadata": {"bu": "hr"}}'

# --- Ollama ---
OLLAMA_BASE_URL=http://ollama:11434

# --- Backend ---
BACKEND_PORT=8000
